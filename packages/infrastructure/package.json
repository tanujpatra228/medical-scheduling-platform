{
  "name": "@msp/infrastructure",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' -r tsconfig-paths/register --files src/database/seeds/run-seed.ts",
    "reset:db": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' -r tsconfig-paths/register --files src/database/seeds/run-reset.ts"
  },
  "dependencies": {
    "@msp/application": "workspace:*",
    "@msp/domain": "workspace:*",
    "@msp/shared": "workspace:*",
    "argon2": "^0.44.0",
    "bullmq": "^5.70.0",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.1",
    "pg": "^8.18.0",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.11",
    "@types/uuid": "^11.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
