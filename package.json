{
  "name": "medical-scheduling-platform",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@8.0.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "start": "pnpm --filter @msp/api start & pnpm --filter web preview",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "seed:db": "pnpm --filter @msp/infrastructure seed",
    "reset:db": "pnpm --filter @msp/infrastructure reset:db"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
